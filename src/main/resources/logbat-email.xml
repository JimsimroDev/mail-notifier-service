<configuration>

    <!-- Appender consola -->
    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Appender archivo -->
    <appender name="FileOut" class="ch.qos.logback.core.FileAppender">
        <file>D:/work/log4j-javaTes.txt</file>
        <append>true</append>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Logger específico -->
    <logger name="uk.jimsimrodev.notifier" level="DEBUG"/>

    <!-- Root logger -->
    <root level="DEBUG">
        <appender-ref ref="console"/>
        <appender-ref ref="FileOut"/>
    </root>

</configuration>