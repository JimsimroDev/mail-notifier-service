<Configuration>
    <Appenders>

        <Console name="Console" target="SYSTEM.OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} %msg%n" />
        </Console>

        <File name="FileOut" fileName="D:/work/log4j-javaTes.txt">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} %msg%n" />
        </File>
    </Appenders>
    <Loggers>
        <Root Level="DEBUG">
            <AppenderRef ref="Console" />
            <AppenderRef ref="FileOut" />
        </Root>
    </Loggers>
</Configuration>